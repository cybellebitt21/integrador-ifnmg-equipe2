// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  // No Prisma 7, a string de conexão física não fica mais aqui.
  // Ela é lida dinamicamente pelo arquivo prisma.config.ts através do .env
}

generator client {
  provider = "prisma-client-js"
  // No Prisma 7, o output customizado foi removido. Os tipos são injetados 
  // automaticamente dentro de node_modules/@prisma/client/ de forma padrão.
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String
  criado_em DateTime @default(now())

  plantacoes Plantacao[]
  alertas    Alerta[]
}

model Plantacao {
  id                   Int       @id @default(autoincrement())
  usuario_id           Int
  nome                 String
  tipo                 String
  data_inicio          DateTime
  data_colheita        DateTime?
  data_proximo_plantio DateTime?
  descricao            String?
  criado_em            DateTime  @default(now())

  usuario  Usuario           @relation(fields: [usuario_id], references: [id])
  sensores PlantacaoSensor[]
}

model Sensor {
  id        Int      @id @default(autoincrement())
  nome      String
  tipo      String
  unidade   String
  criado_em DateTime @default(now())

  // O catálogo agora guarda apenas os metadados de engenharia do hardware puro.
  plantacoes PlantacaoSensor[]
}

// Entidade Associativa que vincula o Sensor à Plantação e define as regras de negócio customizadas do plantio
model PlantacaoSensor {
  id           Int     @id @default(autoincrement())
  plantacao_id Int
  sensor_id    Int
  ativo        Boolean @default(true)

  // MIGRAÇÃO REALIZADA: Os limites agora pertencem ao contexto do cultivo e não ao hardware estático
  limite_atencao Float
  limite_critico Float

  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])
  sensor    Sensor    @relation(fields: [sensor_id], references: [id])
  leituras  Leitura[]

  @@unique([plantacao_id, sensor_id])
}

model Leitura {
  id                  Int      @id @default(autoincrement())
  plantacao_sensor_id Int
  valor               Float
  data_hora           DateTime @default(now())

  vinculo_sensor PlantacaoSensor @relation(fields: [plantacao_sensor_id], references: [id])
  alertas        Alerta[]
}

model Alerta {
  id          Int      @id @default(autoincrement())
  leitura_id  Int
  usuario_id  Int
  tipo        String
  mensagem    String
  notificacao Boolean  @default(false)
  gerado_em   DateTime @default(now())

  leitura Leitura @relation(fields: [leitura_id], references: [id])
  usuario Usuario @relation(fields: [usuario_id], references: [id])
}
