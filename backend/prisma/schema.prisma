// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String
  criado_em DateTime @default(now())

  plantacoes Plantacao[]
  alertas    Alerta[]
}

// Nova tabela para armazenar edge devices
model Dispositivo {
  id        Int      @id @default(autoincrement())
  nome      String // Ex: "Arduino Mega 2560 - Kit 01"
  tipo      String // Ex: "Arduino Mega", "ESP32", "Arduino Nano"
  status    String // Ex: "ATIVO", "INATIVO", "MANUTENCAO"
  criado_em DateTime @default(now())

  // Relacionamento inverso um-para-um com Plantação
  plantacao Plantacao?
}

model Plantacao {
  id                   Int       @id @default(autoincrement())
  usuario_id           Int
  dispositivo_id       Int?      @unique // FK Única: Garante apenas 1 dispositivo por plantação
  nome                 String
  tipo                 String
  data_inicio          DateTime
  data_colheita        DateTime?
  data_proximo_plantio DateTime?
  descricao            String?
  criado_em            DateTime  @default(now())

  usuario     Usuario           @relation(fields: [usuario_id], references: [id])
  dispositivo Dispositivo?      @relation(fields: [dispositivo_id], references: [id]) // Ligação com o Hardware
  sensores    PlantacaoSensor[]
  leituras    Leitura[] // Novo: Relacionamento direto para armazenar o historico linear
  alertas     Alerta[] // Novo: Relacionamento direto para facilitar a listagem de alertas por cultivo
}

model Sensor {
  id        Int      @id @default(autoincrement())
  nome      String
  tipo      String
  unidade   String
  status    String   @default("ATIVO") // Novo: Ex: "ATIVO", "INATIVO", "MANUTENCAO" 
  criado_em DateTime @default(now())

  plantacoes PlantacaoSensor?
  // ALTERADO: Agora é opcional (1 para 1 virtual), pois o sensor físico só pode estar em 0 ou 1 plantação.
}

// Entidade Associativa que vincula o Sensor à Plantação e define as regras de negócio customizadas do plantio
model PlantacaoSensor {
  id           Int     @id @default(autoincrement())
  plantacao_id Int
  sensor_id    Int     @unique // NOVO: @unique garente que o sensor especifico seja usado em apenas uma plantação por vez
  ativo        Boolean @default(true)

  limite_atencao Float
  limite_critico Float

  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])
  sensor    Sensor    @relation(fields: [sensor_id], references: [id])

  @@unique([plantacao_id, sensor_id])
}

// Tabela de Leitura Otimizada: Armazena o pacote consolidado enviado pelo hardware em uma unica linha
model Leitura {
  id           Int      @id @default(autoincrement())
  plantacao_id Int // Alterado: Aponta direto para a plantacao contendo o dispositivo de borda
  data_hora    DateTime @default(now())

  // Colunas de telemetria lineares (Opcionais para cenarios onde o sensor nao esteja instalado)
  luminosidade Float?
  temperatura  Float?
  umidade_ar   Float?
  umidade_solo Float?

  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])
  alertas   Alerta[]
}

model Alerta {
  id           Int      @id @default(autoincrement())
  leitura_id   Int
  usuario_id   Int
  plantacao_id Int // Novo: Facilita indexar e buscar alertas direto por area de cultivo
  tipo         String
  mensagem     String
  notificacao  Boolean  @default(false)
  gerado_em    DateTime @default(now())

  leitura   Leitura   @relation(fields: [leitura_id], references: [id])
  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])
}
