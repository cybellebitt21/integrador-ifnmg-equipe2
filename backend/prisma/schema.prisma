// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String
  criado_em DateTime @default(now())

  plantacoes Plantacao[]
  alertas    Alerta[]

  @@map("usuario")
}

enum statusDispositivo {
  Ativo
  Inativo
}

enum statusSensor {
  Ativo
  Inativo
}

enum tipoSensor {
  temperatura
  umidade_ar   @map("Umidade do Ar")
  umidade_solo @map("Umidade do Solo")
  luminosidade
}

enum tipoAlerta {
  Atencao
  Critico
}

enum tipoDispositivo {
  Arduino_Mega     @map("Arduino Mega")
  Arduino_Micro    @map("Arduino Micro")
  Arduino_Nano     @map("Arduino Nano")
  Arduino_Uno      @map("Arduino Uno")
  Arduino_Leonardo @map("Arduino Leonardo")
  ESP32
  ESP8266
}

model Dispositivo {
  id        Int               @id @default(autoincrement())
  nome      String // Ex: "Arduino Mega 2560 - Kit 01"
  tipo      tipoDispositivo
  status    statusDispositivo @default(Inativo)
  criado_em DateTime          @default(now())

  // Relacionamento um-para-um com Plantação
  plantacao Plantacao?

  @@map("dispositivo")
}

model Plantacao {
  id                   Int       @id @default(autoincrement())
  usuario_id           Int
  dispositivo_id       Int       @unique // FK: Garante apenas 1 dispositivo por plantação
  nome                 String
  tipo                 String
  data_inicio          DateTime
  data_colheita        DateTime?
  data_proximo_plantio DateTime?
  descricao            String?
  criado_em            DateTime  @default(now())

  usuario     Usuario           @relation(fields: [usuario_id], references: [id])
  dispositivo Dispositivo       @relation(fields: [dispositivo_id], references: [id])
  sensores    PlantacaoSensor[]
  leituras    Leitura[]
  alertas     Alerta[] // Relacionamento direto para facilitar a listagem de alertas por cultivo

  @@map("plantacao")
}

model Sensor {
  id        Int          @id @default(autoincrement())
  nome      String // Ex: "Sensor de Temperatura DHT11"
  tipo      tipoSensor
  unidade   String // Ex: "°C", "%", "Lux"
  status    statusSensor @default(Inativo)
  criado_em DateTime     @default(now())

  plantacoes PlantacaoSensor? // permite o sensor não estar em nenhuma plantação

  @@map("sensor")
}

model PlantacaoSensor {
  id           Int     @id @default(autoincrement())
  plantacao_id Int
  sensor_id    Int     @unique
  limite_atencao Float
  limite_critico Float

  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])
  sensor    Sensor    @relation(fields: [sensor_id], references: [id])

  @@unique([plantacao_id, sensor_id]) // Impede duplicar o mesmo sensor na mesma plantação
  @@map("plantacao_sensor")
}

model Leitura {
  id           Int      @id @default(autoincrement())
  plantacao_id Int
  data_hora    DateTime @default(now())
  luminosidade Float?
  temperatura  Float?
  umidade_ar   Float?
  umidade_solo Float?

  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])
  alertas   Alerta[]

  @@map("leitura")
}

model Alerta {
  id           Int      @id @default(autoincrement())
  leitura_id   Int
  usuario_id   Int
  plantacao_id Int // Facilita indexar e buscar alertas direto por plantação
  tipo         tipoAlerta
  mensagem     String
  notificacao  Boolean  @default(false)
  gerado_em    DateTime @default(now())

  leitura   Leitura   @relation(fields: [leitura_id], references: [id])
  usuario   Usuario   @relation(fields: [usuario_id], references: [id])
  plantacao Plantacao @relation(fields: [plantacao_id], references: [id])

  @@map("alerta")
}
