// ------------ Código para simular o gateway de forma autonôma ------------
void setup() {
  Serial.begin(115200);
  randomSeed(analogRead(A5));
}

void loop() {
  delay(5000);

  unsigned int umidadeSolo = random(20, 86);

  float umidadeAr = random(400, 701) / 10.0;
  float temperatura = random(210, 341) / 10.0;

  unsigned int luminosidade = random(10, 96);

  Serial.print(umidadeSolo);
  Serial.print(F(","));
  Serial.print(umidadeAr);
  Serial.print(F(","));
  Serial.print(temperatura);
  Serial.print(F(","));
  Serial.println(luminosidade);
}
